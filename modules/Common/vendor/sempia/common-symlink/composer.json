{
    "name": "sempia/common-symlink",
    "type": "composer-plugin",
    "version": "1.0.0",
    "description": "Composer plugin to create symlink for Omeka S module Common (backward compatibility with old modules)",
    "license": "CECILL-2.1",
    "keywords": ["omeka-s", "common", "symlink", "composer-plugin"],
    "homepage": "https://gitlab.com/sempia/composer-plugin-common-symlink",
    "authors": [
        {
            "name": "Daniel Berthereau",
            "email": "Daniel.fr@Berthereau.net"
        }
    ],
    "require": {
        "php": ">=7.4",
        "composer-plugin-api": "^2.0"
    },
    "require-dev": {
        "composer/composer": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Sempia\\CommonSymlink\\": "src/"
        }
    },
    "extra": {
        "class": "Sempia\\CommonSymlink\\CommonSymlinkPlugin"
    },
    "config": {
        "sort-packages": true
    }
}
