$itemCache = [];

function getItemCached($id, $site, &$cache) {
  if (!isset($cache[$id])) {
    $cache[$id] = $site->api()->read('items', $id)->getContent();
  }
  return $cache[$id];
}

$subjectCache = [];

function getSubjectValuesCached($id, $site) {
  global $subjectCache, $itemCache;
  if (!isset($subjectCache[$id])) {
    $item = getItemCached($id, $site, $itemCache);
    $subjectCache[$id] = $item->subjectValues();
  }
  return $subjectCache[$id];
}

$query = $this->params()->fromQuery();

// search an item and get data with given id
function searchElement($id, $site) {
  global $itemCache;
  return getItemCached($id, $site, $itemCache);
}


//get the childs of an element 
function getSubjectValues($id, $site) {
  global $itemCache, $subjectCache;
  return getSubjectValuesCached($id, $site, $itemCache, $subjectCache);
}


//take requestedItems out the url get requested
if (isset($_GET['requestedItem'])) {
  $getRequest = $_GET['requestedItem'];

  $response = $this->api()->searchOne('items', [
    'property' => [
      [
        'property' => 'schema:alternateName',
        'type' => 'eq',
        'text' => $getRequest
      ]
    ]
  ]);

  $requestedRes = $response->getContent();

  //get the get request and take the id of that item
  $resId = $requestedRes->value('schema:alternateName');
  $resInternalId = $requestedRes->id();


  //array for the pad to the top structure
  $resPathId = [
    [
      'altId' => $resId,
      'id' => $resInternalId
    ]
  ];

  $currentRes = $requestedRes;

  //get the rootfolder of the item until we are at the top and push the id in the resPathId array
  while($currentRes->value('schema:isPartOf', ['type' => 'resource'])){
    $rootfolder = $currentRes->value('schema:isPartOf', ['type' => 'resource']);

    $parentRes = $rootfolder->valueResource();

    $altId = $parentRes->value('schema:alternateName');
    $internalId = $parentRes->id();

    array_unshift($resPathId, [
      'altId' => $altId,
      'id' => $internalId
    ]);

    $currentRes = $parentRes;
  };
  $rootId = $resPathId[0]['id'];
}

$this->htmlElement('body')->appendAttribute('class', 'page');

function renderTree($rootId, $resPathId, $site, $context, $options = [], $level = 0, $parentId = null) {
  global $itemCache;

  $id = ($level === 0) ? $rootId : $parentId;

  $children = getSubjectValuesCached($id, $context);
  if (!isset($children["isPartOf"])) {
    return;
  }

  // Verzamel children
  $childResources = [];
  foreach ($children["isPartOf"] as $child) {
    $childResources[] = $child['val']->resource();
  }

  // Sorteer
  usort($childResources, function ($a, $b) {
    return strnatcmp(
      $a->value("schema:identifier") ?? '',
      $b->value("schema:identifier") ?? ''
    );
  });?>

  <ul class="browse-items inner-browse-items">
    <?php foreach ($childResources as $childRes) {
      $childId = $childRes->id();
      $identifier = $childRes->value("schema:identifier");
      $altName = $childRes->value("schema:alternateName");

      $element = getItemCached($childId, $context, $itemCache);
      $template = $element->resourceTemplate()->label();

      $isOpen = (isset($resPathId[$level + 1]) && $childId == $resPathId[$level + 1]['id']);

      $typeClass = ($template === ($options['folderTemplate'] ?? 'Archival folder'))
        ? 'folder'
        : 'page-item';

      $url = $site->url() . '/item/browse/?requestedItem=' . $altName;
    ?>
      <li class="browse-items__browse-item browse-item big-body-text">
        <p class="browse-item-link <?= ($isOpen ? 'open' : 'close') ?> <?= $typeClass ?>" data-link="<?= $url ?>" onclick="saveBrowseData(event)">
          <?= $identifier ?>
          <span class="arrow-after"></span>
        </p>

        <?php if ($isOpen) {
          renderTree($rootId, $resPathId, $site, $context, $options, $level + 1, $childId);
        } ?>
      </li>
    <?php } ?>
  </ul>
<?php } ?>

