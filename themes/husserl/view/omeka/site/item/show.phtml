<?php
class EmptyValue {
  public $type;
  public $value;

  public function __construct($type, $value) {
    $this->type = $type;
    $this->value = $value;
  }

  public function type() {
    return $this->type;
  }

  public function asHtml() {
    return "<span>{$this->value}</span>";
  }
};

$itemCache = [];

function getItemCached($id, $site, &$cache) {
  if (!isset($cache[$id])) {
    $cache[$id] = $site->api()->read('items', $id)->getContent();
  }
  return $cache[$id];
}

function searchElement($id, $site) {
  global $itemCache;
  return getItemCached($id, $site, $itemCache);
}

//array for the pad to the top structure
$resId = $item->value('schema:alternateName');
$resInternalId = $item->id();
$resPathId = [
  [
    'altId' => $resId,
    'id' => $resInternalId
  ]
];
$res = $item;

//get the rootfolder of the item until we are at the top and push the id in the resPathId array
while($res->value('schema:isPartOf', ['type' => 'resource'])){
  $rootfolder = $res->value('schema:isPartOf', ['type' => 'resource']);
  
  $parentRes = $rootfolder->valueResource();

  $altId = $parentRes->value('schema:alternateName');
  $internalId = $parentRes->id();

  array_unshift($resPathId, [
    'altId' => $altId,
    'id' => $internalId
  ]);
  
  $res = $parentRes;
};

