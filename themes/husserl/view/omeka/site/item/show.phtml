function searchElement($id, $site) {
    $element = $site->api()->read('items', $id, []);
    $element = $element->getContent();

    return $element;
}

function getSubjectValues($id, $site) {
    $element = searchElement($id, $site);
    $children = $element->subjectValues();

    return $children;
}

